# ============================================================================
# Cloud Storage - Railway Deployment Environment Variables Template
# ============================================================================
# 
# COPY THIS FILE (rename to .env or .env.production) and fill in your values
# DO NOT COMMIT TO GIT - use Railway Dashboard to set these variables
#
# ============================================================================

# ============================================================================
# Development / Production Environment
# ============================================================================
NODE_ENV=production
PORT=8080

# ============================================================================
# Database Configuration
# ============================================================================
# Railway akan auto-generate ini untuk MySQL service
# Format: mysql://user:password@host:port/database
DATABASE_URL=mysql://user:password@localhost:3306/finance_manager

# ============================================================================
# Authentication - OAuth Configuration
# ============================================================================

# Google OAuth (untuk social login)
OAUTH_GOOGLE_CLIENT_ID=your_google_client_id_here
OAUTH_GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# OAuth Redirect URI (ganti dengan Railway domain Anda)
# Format: https://<your-railway-url>.up.railway.app/auth/callback
OAUTH_REDIRECT_URI=https://finance-manager.up.railway.app/auth/callback

# Owner OpenID - untuk setup admin account
# Ganti dengan Google ID Anda yang akan menjadi owner/admin
OWNER_OPEN_ID=your_google_id@gmail.com

# ============================================================================
# AWS S3 Configuration (Optional - untuk Cloud Backup Feature)
# ============================================================================

AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_S3_BUCKET=your_s3_bucket_name
AWS_S3_REGION=us-east-1

# ============================================================================
# Application Settings
# ============================================================================

# API Configuration
VITE_API_BASE_URL=https://finance-manager.up.railway.app
VITE_APP_NAME=Finance Manager

# Enable Features
ENABLE_CLOUD_BACKUP=true
ENABLE_AI_CHAT=true  # Memerlukan API keys

# ============================================================================
# Manus / Custom Provider Configuration (Optional)
# ============================================================================

MANUS_PROVIDER_URL=https://api.manus.app
MANUS_API_KEY=your_manus_api_key

# ============================================================================
# SETUP INSTRUCTIONS
# ============================================================================
#
# 1. Akses Railway Dashboard: https://dashboard.railway.app
#
# 2. Di project settings, pilih "Variables" tab
#
# 3. Tambahkan setiap variable di bawah:
#    - NODE_ENV: production
#    - DATABASE_URL: (auto-generated oleh Railway MySQL)
#    - OAUTH_GOOGLE_CLIENT_ID
#    - OAUTH_GOOGLE_CLIENT_SECRET
#    - OAUTH_REDIRECT_URI
#    - OWNER_OPEN_ID
#    - [Optional] AWS_* untuk S3
#
# 4. Deploy ulang project Anda
#
# 5. Run migration: 
#    railway run npm run db:push
#
# ============================================================================
# SECURITY NOTES
# ============================================================================
#
# ⚠️  NEVER commit secrets ke Git
# ⚠️  Use Railway Dashboard Variables editor untuk production secrets
# ⚠️  Rotate AWS keys secara berkala
# ⚠️  Enable Railway's 2FA untuk extra security
# ⚠️  Monitor Railway logs untuk error/unauthorized access
#
# ============================================================================
